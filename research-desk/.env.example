# The Research Desk runs as a long-lived server: the server holds the
# credential, the browser never needs a key. Copy to .env.local for next dev,
# or pass as container env vars.

# One of the two (sk-ant-api... key, or an sk-ant-oat0... access token):
ANTHROPIC_API_KEY=
# ANTHROPIC_AUTH_TOKEN=

# The SEC requires a contact identity on automated EDGAR requests.
EDGAR_IDENTITY="Your Name you@example.com"

# Optional overrides
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# MANAGED_AGENTS_PREVIEW_BETA=managed-agents-2026-04-01
# DESK_CONCURRENCY=4
# Workspace slug used in Console deep links (Setup tab, session links).
# ANTHROPIC_WORKSPACE_SLUG=default
